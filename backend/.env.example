DATABASE_URL=sqlite:///./backend/logx.db
ALLOWED_ORIGINS=*
ATTACHMENTS_DIR=backend/storage/attachments

# Embedding runtime configuration
EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=64

# Optional Azure OpenAI embedding provider (used when EMBEDDING_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# Vector store backend: database (default) or opensearch
VECTOR_STORE_BACKEND=database
OPENSEARCH_URL=
OPENSEARCH_INDEX=logx-node-embeddings
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# Optional behavioral clustering runtime defaults (Phase 2)
CLUSTERING_MIN_SAMPLES=6
CLUSTERING_MAX_SAMPLES=5000

# Phase 3 intervention runtime
INTERVENTION_ENABLED=true
INTERVENTION_PROFILE_KEY=global
INTERVENTION_SIMILARITY_THRESHOLD=0.85
INTERVENTION_HISTORY_MATCH_COUNT=5

# OpenAI LLM for intervention generation
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
INTERVENTION_LLM_MODEL=gpt-4.1-mini
INTERVENTION_LLM_TIMEOUT_SECONDS=14

# Phase 4 retrospective synthesis
RETROSPECTIVE_LLM_PROVIDER=auto
RETROSPECTIVE_LLM_MODEL=gpt-4.1-mini
RETROSPECTIVE_LLM_TIMEOUT_SECONDS=24
RETROSPECTIVE_DEFAULT_DAYS=7
RETROSPECTIVE_MAX_TRADES=250
